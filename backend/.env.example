# Unthinkable Health - Backend Environment Variables

# Database Configuration
# You can use a local SQLite database for testing, or a PostgreSQL connection string (like Neon) for production.
# IMPORTANT: For asyncpg (FastAPI), the scheme must be postgresql+asyncpg://
DATABASE_URL=sqlite+aiosqlite:///./test.db
# Example for Neon Postgres:
# DATABASE_URL=postgresql+asyncpg://user:password@ep-cool-snowflake-1234.us-east-2.aws.neon.tech/neondb

# Security
# Run `openssl rand -hex 32` to generate a secure secret key
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Configuration (Groq API)
# Get a free API key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Email Configuration (Brevo API)
# Get a free API key at https://app.brevo.com/settings/keys/api
# Used for sending appointment confirmations and ICS calendar invites
BREVO_API_KEY=xkeysib-your_brevo_api_key_here
FROM_EMAIL=noreply@unthinkable-health.com

# Testing
# Set to 'True' to mock email sending (prints to console instead of sending)
MOCK_EMAIL=False
